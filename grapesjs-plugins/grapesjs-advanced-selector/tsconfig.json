{
  "compilerOptions": {
    "resolveJsonModule": true,
    "skipLibCheck": true, // For grapesjs in headless mode
    "esModuleInterop": true, // For grapesjs in headless mode
    "target": "es2019",
    "module": "es2020",
    "lib": ["es2022", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "plugins": [
      {
        "name": "ts-lit-plugin",
        "strict": true
      }
    ],
    "types": ["jest"]
  },
  "include": ["src/**/*.ts", "src/model.test.js"],
  "exclude": []
}
