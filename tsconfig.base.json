{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "paths": {
      "~/common": ["./common"],
      "~/common/*": ["./common/*"],
      "~/editor/*": ["./editor/*"],
      "~/server/*": ["./server/*"],
      "~/grapesjs-plugins/*": ["./grapesjs-plugins/*"]
    }
  }
}
